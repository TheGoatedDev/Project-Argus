{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "//#format-and-lint": {
            "cache": true,
            "inputs": ["**/*.ts", "**/*.tsx", "**/*.json", "biome.json"],
            "outputs": []
        },
        "build": {
            "dependsOn": ["^build", "typecheck"],
            "inputs": ["src/**", "package.json", "tsconfig.json"],
            "outputs": ["dist/**", ".next/**"],
            "cache": true
        },
        "typecheck": {
            "dependsOn": ["^build"],
            "inputs": ["src/**/*.ts", "src/**/*.tsx", "tsconfig.json"],
            "outputs": [],
            "cache": true
        },
        "test": {
            "dependsOn": ["^build"],
            "inputs": ["src/**", "__tests__/**", "vitest.config.ts"],
            "outputs": ["coverage/**"],
            "cache": true
        },
        "e2e": {
            "dependsOn": ["^build"],
            "inputs": ["tests/**", "playwright.config.ts"],
            "outputs": ["test-results/**", "playwright-report/**"],
            "passThroughEnv": ["PLAYWRIGHT_*", "API_URL"],
            "cache": false
        },
        "dev": {
            "cache": false,
            "persistent": true,
            "interactive": true
        }
    },
    "globalDependencies": ["package.json", "pnpm-lock.yaml"],
    "globalPassThroughEnv": ["NODE_ENV", "CI"]
}
